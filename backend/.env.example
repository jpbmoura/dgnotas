NODE_ENV=development
PORT=4000

# CORS — em prod (mesmo host), use a URL pública do Railway.
FRONTEND_ORIGIN=http://localhost:5173

# Postgres — em prod, use a variável injetada pelo plugin Postgres do Railway
# (tipicamente a DATABASE_URL privada). SSL é habilitado automaticamente em prod.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Better Auth
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-32-byte-base64-string
# URL pública da aplicação — em prod aponta para o domínio do Railway
# (mesmo host do FRONTEND_ORIGIN, já que o backend serve a SPA).
BETTER_AUTH_URL=http://localhost:5173
